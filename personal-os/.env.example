# Copia este archivo como .env (en backend/) para desarrollo local si quieres
# fijar valores en vez de usar los por defecto. En Railway, estas se
# configuran como variables de entorno del servicio, no como archivo.

# Entorno: "production" hace que el backend también sirva el frontend
# compilado (frontend/dist) desde el mismo puerto. En local normalmente no
# se necesita (usa start.sh, que corre frontend y backend por separado).
NODE_ENV=development

# Puerto del servidor (Railway lo inyecta automáticamente, no hace falta
# definirlo ahí).
PORT=4000

# Contraseña de acceso a la app. OBLIGATORIO definirla en producción.
# Si no se define, se usa "cambiame123" como contraseña por defecto, lo
# cual NO es seguro para algo expuesto a internet.
APP_PASSWORD=cambia-esta-clave

# Secreto usado para firmar las sesiones (JWT). OBLIGATORIO en producción.
# Genera uno único, por ejemplo con: openssl rand -hex 32
JWT_SECRET=reemplaza-esto-por-un-secreto-largo-y-aleatorio

# Solo se usa en desarrollo, para permitir que el frontend (Vite, puerto
# 5173) llame al backend con cookies entre puertos distintos.
FRONTEND_URL=http://localhost:5173

# Carpeta donde se guarda personal-os.db. En Railway, debe apuntar a la
# ruta donde montaste el volumen persistente (ej: /data).
DATA_DIR=./db
